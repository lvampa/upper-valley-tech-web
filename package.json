{
  "name": "upper-valley-tech-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write . --config config/prettier.json --ignore-path config/.prettierignore",
    "format:check": "prettier --check . --config config/prettier.json --ignore-path config/.prettierignore",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ladle": "ladle serve",
    "ladle:build": "ladle build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ladle/react": "^5.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "npm:rolldown-vite@7.2.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@7.2.2"
  },
  "dependencies": {
    "@hcaptcha/vanilla-hcaptcha": "^1.1.4",
    "@t3-oss/env-core": "^0.13.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  }
}
